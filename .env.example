PORT=5000
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_string_here_abc123def456ghi789
MONDAY_API_TOKEN=YOUR_MONDAY_API_TOKEN_HERE
MONDAY_CLIENT_ID=YOUR_MONDAY_CLIENT_ID_HERE
MONDAY_CLIENT_SECRET=YOUR_MONDAY_CLIENT_SECRET_HERE
ALLOWED_ORIGINS=http://localhost:5173,https://client-portal-seven-alpha.vercel.app

# Local SQLite fallback. Leave this set for local dev/tests.
DATABASE_FILE=database.sqlite

# Vercel/Turso serverless database. Set these in Vercel instead of DATABASE_FILE.
# TURSO_AUTH_TOKEN must be generated for the database in TURSO_DATABASE_URL.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=YOUR_TURSO_AUTH_TOKEN

MONDAY_TEST_ACCOUNT_ID=123456789
MONDAY_TEST_BOARD_ID=123456
LOCAL_ADMIN_TOKEN=local-dev-admin-token
LOCAL_ADMIN_ACCOUNT_ID=123456789
